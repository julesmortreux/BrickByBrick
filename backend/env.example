# ============================================================================
# BRICKBYBRICK - Configuration Backend
# ============================================================================
# Copiez ce fichier en .env et remplissez les valeurs

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Database (PostgreSQL) - À configurer plus tard
DATABASE_URL=postgresql://user:password@localhost:5432/brickbybrick
DB_ECHO=False

# Security - À générer avec: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins (séparés par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ScraperAPI (pour le scraping SeLoger)
# Obtenir une clé gratuite sur : https://www.scraperapi.com/signup
# Plan gratuit : 1000 crédits/mois (~100-200 annonces)
SCRAPERAPI_KEY=your-scraperapi-key-here

# Logging
LOG_LEVEL=INFO

# Data Directory (optionnel, par défaut: ../data)
DATA_DIR=../data

# Environment
ENVIRONMENT=development
